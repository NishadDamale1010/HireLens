# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/HireLens?retryWrites=true&w=majority

# ─── AI Providers (add at least ONE key) ─────────────────────────────────────

# 1. OpenRouter — https://openrouter.ai/keys
#    Free model used: meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=sk-or-v1-...

# 2. Google Gemini — https://aistudio.google.com/app/apikey
#    Free model used: gemini-2.0-flash
GEMINI_API_KEY=AIza...

# 3. Groq — https://console.groq.com/keys
#    Free model used: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_...

# ─── Production only ──────────────────────────────────────────────────────────
# Set this to your deployed frontend URL to allow CORS
# FRONTEND_URL=https://hirelens.vercel.app
